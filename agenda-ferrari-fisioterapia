<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Painel de Agendamento | Ferrari Fisioterapia</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: #f2f2f7;
            background-image: 
                radial-gradient(at 0% 0%, hsla(210, 100%, 93%, 1) 0, transparent 50%), 
                radial-gradient(at 50% 0%, hsla(225, 100%, 95%, 1) 0, transparent 50%), 
                radial-gradient(at 100% 0%, hsla(180, 100%, 93%, 1) 0, transparent 50%);
            background-attachment: fixed;
            color: #1d1d1f;
            display: flex;
            justify-content: center;
            padding: 40px 20px;
            margin: 0;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            width: 100%;
            max-width: 600px;
            padding: 40px;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
            box-sizing: border-box;
        }

        h2 {
            text-align: center;
            font-weight: 600;
            font-size: 24px;
            letter-spacing: -0.5px;
            margin-top: 0;
            margin-bottom: 30px;
            color: #1d1d1f;
        }

        label {
            font-weight: 500;
            display: block;
            margin-top: 20px;
            color: #86868b;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input[type="text"], input[type="date"], input[type="time"], input[type="number"], input[type="email"], select {
            width: 100%;
            padding: 14px 16px;
            margin-top: 8px;
            background: rgba(255, 255, 255, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 12px;
            box-sizing: border-box;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            color: #1d1d1f;
            outline: none;
            transition: all 0.3s ease;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
            -webkit-appearance: none; 
        }

        input:focus, select:focus {
            background: rgba(255, 255, 255, 0.8);
            border-color: #007aff;
            box-shadow: 0 0 0 4px rgba(0, 122, 255, 0.1);
        }

        .input-group {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .btn-novo-cliente {
            background: #007aff; 
            color: #ffffff;
            border: none;
            padding: 14px 20px;
            border-radius: 20px; 
            cursor: pointer;
            font-weight: 500;
            margin-top: 8px; 
            transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            white-space: nowrap;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            box-shadow: 0 4px 12px rgba(0, 122, 255, 0.3); 
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-novo-cliente:hover {
            background: #0062cc;
            transform: translateY(-1px) scale(0.98);
            box-shadow: 0 6px 15px rgba(0, 122, 255, 0.4);
        }

        .btn-novo-cliente.modo-cancelar {
            background: #ff3b30; 
            box-shadow: 0 4px 12px rgba(255, 59, 48, 0.3);
        }

        .grid-2, .grid-3 { display: flex; gap: 16px; }
        .grid-2 > div, .grid-3 > div { flex: 1; }
        
        .radio-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 12px;
        }

        .radio-group label {
            margin-top: 0;
            text-transform: none;
            letter-spacing: 0;
            color: #1d1d1f;
            font-size: 14px;
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.6);
            padding: 14px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.8);
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .checkbox-group {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px;
            margin-top: 12px;
        }

        .checkbox-group label {
            margin-top: 0;
            text-transform: none;
            letter-spacing: 0;
            color: #1d1d1f;
            font-size: 14px;
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.4);
            padding: 10px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.5);
            cursor: pointer;
            transition: background 0.2s;
        }

        button[type="submit"] {
            width: 100%;
            padding: 16px;
            background-color: #1d1d1f;
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 500;
            margin-top: 35px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            letter-spacing: -0.2px;
        }

        #painelOpcoesPacote, #painelDias, #painelNovoCliente {
            display: none;
            background: rgba(255, 255, 255, 0.4);
            padding: 24px;
            border-radius: 16px;
            margin-top: 20px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: inset 0 2px 10px rgba(255,255,255,0.5);
        }

        .titulo-secao {
            color: #1d1d1f;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            margin-top: 0;
            letter-spacing: -0.3px;
        }

        .erro-texto { color: #ff3b30; font-size: 12px; margin-top: 8px; display: none; font-weight: 500; }

        @media (max-width: 600px) {
            body { padding: 15px 10px; }
            .container { padding: 25px 20px; border-radius: 20px; }
            .grid-2, .grid-3 { flex-direction: column; gap: 0; }
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Agenda: Ferrari Fisioterapia</h2>
    
    <form id="formAgendamento">
        <label for="pacienteSelect">Paciente / Processo</label>
        <div class="input-group">
            <select id="pacienteSelect" name="pacienteSelect" required>
                <option value="">Carregando pacientes...</option>
            </select>
            <button type="button" id="btnAtivarNovo" class="btn-novo-cliente" onclick="alternarNovoCliente()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Novo Cliente
            </button>
        </div>

        <div id="painelNovoCliente">
            <h3 class="titulo-secao">Dados de Faturamento</h3>
            <label for="novoNome" style="margin-top: 0;">Nome / Razão Social</label>
            <input type="text" id="novoNome">

            <div class="grid-2">
                <div>
                    <label for="novoDoc">CPF / CNPJ</label>
                    <input type="text" id="novoDoc" onblur="checarDocumento()" maxlength="18">
                    <div id="erroDoc" class="erro-texto">Documento Inválido</div>
                </div>
                <div>
                    <label for="novoTel">WhatsApp</label>
                    <input type="text" id="novoTel" placeholder="(XX) 9XXXX-XXXX">
                </div>
            </div>

            <label for="novoEmail">E-mail</label>
            <input type="email" id="novoEmail" placeholder="paciente@email.com">

            <div class="grid-2">
                <div><label for="novoCep">CEP</label><input type="text" id="novoCep" onblur="buscarCEP()"></div>
                <div><label for="novoRua">Endereço</label><input type="text" id="novoRua"></div>
            </div>

            <div class="grid-3">
                <div><label for="novoNum">Número</label><input type="text" id="novoNum"></div>
                <div><label for="novoBairro">Bairro</label><input type="text" id="novoBairro"></div>
                <div><label for="novoCidade">Cidade/UF</label><input type="text" id="novoCidade"></div>
            </div>
        </div>

        <label for="servico">Serviço Prestado</label>
        <select id="servico" name="servico" required>
            <option value="">Selecione...</option>
            <optgroup label="Clínica e Reabilitação">
                <option value="Fisioterapia Homecare">Fisioterapia Homecare</option>
                <option value="Avaliação Fisioterapêutica">Avaliação Fisioterapêutica</option>
                <option value="Consulta Fisioterapêutica">Consulta Fisioterapêutica</option>
            </optgroup>
            <optgroup label="Perícia e Assistência Técnica">
                <option value="Parecer de Viabilidade">Parecer de Viabilidade</option>
                <option value="Quesitos">Quesitos</option>
                <option value="Impugnação + Quesitos Complementares">Impugnação + Quesitos Complementares</option>
                <option value="Avaliação Física c/ Parecer Técnico">Avaliação Física c/ Parecer Técnico</option>
                <option value="Teleconsulta c/ Parecer Simples">Teleconsulta c/ Parecer Simples</option>
            </optgroup>
            <option value="Bloqueio de Agenda">Bloqueio de Agenda</option>
        </select>

        <div class="grid-3">
            <div><label>Data</label><input type="date" id="dataInicio" required></div>
            <div><label>Início</label><input type="time" id="horario" required></div>
            <div><label>Término</label><input type="time" id="horarioFim" required></div>
        </div>

        <label for="qtdSessoes">Total de Sessões (Pacote)</label>
        <input type="number" id="qtdSessoes" value="1" min="1" required oninput="verificarPacote()">

        <div id="painelOpcoesPacote">
            <div class="radio-group">
                <label><input type="radio" name="tipoRecorrencia" value="automatica" checked onchange="verificarTipoRecorrencia()"> Recorrência Semanal</label>
                <label><input type="radio" name="tipoRecorrencia" value="manual" onchange="verificarTipoRecorrencia()"> Manual / Crédito</label>
            </div>
            <div id="painelDias">
                <div class="checkbox-group">
                    <label><input type="checkbox" name="dias" value="Segunda"> Segunda</label>
                    <label><input type="checkbox" name="dias" value="Terça"> Terça</label>
                    <label><input type="checkbox" name="dias" value="Quarta"> Quarta</label>
                    <label><input type="checkbox" name="dias" value="Quinta"> Quinta</label>
                    <label><input type="checkbox" name="dias" value="Sexta"> Sexta</label>
                    <label><input type="checkbox" name="dias" value="Sábado"> Sábado</label>
                </div>
            </div>
        </div>

        <button type="submit" id="btnAgendar">Confirmar Agendamento</button>
    </form>
</div>

<script>
    const URL_SCRIPT = "https://script.google.com/macros/s/AKfycbwXQ1IHa2riVeGGvrCNpGzMll_htz5rPwNbeENLHcKex5mRfQgFDE9sViunwPdNBXG7/exec";
    let modoNovoCliente = false;

    window.onload = function() {
        fetch(URL_SCRIPT)
        .then(res => res.json())
        .then(data => {
            const select = document.getElementById('pacienteSelect');
            select.innerHTML = '<option value="">Selecione na lista...</option>';
            data.forEach(nome => {
                let opt = document.createElement('option');
                opt.value = nome; opt.text = nome;
                select.appendChild(opt);
            });
        });
    };

    function alternarNovoCliente() {
        modoNovoCliente = !modoNovoCliente;
        const painel = document.getElementById('painelNovoCliente');
        const select = document.getElementById('pacienteSelect');
        const btn = document.getElementById('btnAtivarNovo');
        painel.style.display = modoNovoCliente ? 'block' : 'none';
        select.disabled = modoNovoCliente;
        select.required = !modoNovoCliente;
        btn.classList.toggle('modo-cancelar', modoNovoCliente);
        btn.innerHTML = modoNovoCliente ? 'Cancelar' : 'Novo Cliente';
    }

    function verificarPacote() {
        const qtd = parseInt(document.getElementById('qtdSessoes').value) || 1;
        const painelOpcoes = document.getElementById('painelOpcoesPacote');
        painelOpcoes.style.display = (qtd > 1) ? 'block' : 'none';
        // CORREÇÃO DO BUG: Se abrir o painel, verifica imediatamente o tipo de recorrência
        if (qtd > 1) verificarTipoRecorrencia(); 
    }

    function verificarTipoRecorrencia() {
        const radio = document.querySelector('input[name="tipoRecorrencia"]:checked');
        const painelDias = document.getElementById('painelDias');
        // Se estiver em "automatica", mostra os dias. Caso contrário, esconde.
        painelDias.style.display = (radio && radio.value === 'automatica') ? 'block' : 'none';
    }

    function checarDocumento() {
        const input = document.getElementById('novoDoc');
        const valor = input.value.replace(/\D/g, '');
        const valido = (valor.length === 11 || valor.length === 14);
        document.getElementById('erroDoc').style.display = (valor !== '' && !valido) ? 'block' : 'none';
    }

    function buscarCEP() {
        let cep = document.getElementById('novoCep').value.replace(/\D/g, '');
        if (cep.length === 8) {
            fetch(`https://viacep.com.br/ws/${cep}/json/`)
            .then(r => r.json()).then(d => {
                if (!d.erro) {
                    document.getElementById('novoRua').value = d.logradouro;
                    document.getElementById('novoBairro').value = d.bairro;
                    document.getElementById('novoCidade').value = d.localidade + '/' + d.uf;
                }
            });
        }
    }

    document.getElementById('formAgendamento').addEventListener('submit', function(e) {
        e.preventDefault();
        const btn = document.getElementById('btnAgendar');
        btn.innerText = "Processando..."; btn.disabled = true;

        let diasSelt = [];
        document.querySelectorAll('input[name="dias"]:checked').forEach(cb => diasSelt.push(cb.value));
        let enderecoF = modoNovoCliente ? `${document.getElementById('novoRua').value}, ${document.getElementById('novoNum').value}` : "";

        const payload = {
            isNovoCliente: modoNovoCliente,
            paciente: document.getElementById('pacienteSelect').value,
            novoNome: document.getElementById('novoNome').value,
            novoEmail: document.getElementById('novoEmail').value,
            novoTel: document.getElementById('novoTel').value,
            enderecoCompleto: enderecoF,
            servico: document.getElementById('servico').value,
            dataInicio: document.getElementById('dataInicio').value,
            horario: document.getElementById('horario').value,
            horarioFim: document.getElementById('horarioFim').value,
            qtdSessoes: document.getElementById('qtdSessoes').value,
            tipoRecorrencia: document.querySelector('input[name="tipoRecorrencia"]:checked')?.value || "",
            dias: diasSelt.join(', ')
        };

        fetch(URL_SCRIPT, { method: 'POST', body: JSON.stringify(payload) })
        .then(res => res.json())
        .then(res => {
            if (res.status === "parcial") {
                alert("AVISO DE CONFLITO: Algumas sessões foram agendadas, mas houve conflito nos horários: " + res.conflitos.join(', '));
            } else {
                alert("Sucesso! Agendamento realizado.");
            }
            location.reload();
        })
        .catch(() => {
            alert("Erro ao enviar.");
            btn.disabled = false; btn.innerText = "Confirmar Agendamento";
        });
    });
</script>
</body>
</html>
